PORT=4000
NODE_ENV=production
DATABASE_URL=postgres://<user>:<password>@<host>:5432/<database>
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=12h
DEFAULT_ADMIN_EMAIL=admin@yourdomain.com
DEFAULT_ADMIN_PASSWORD=replace-on-first-login
ADMIN_RECOVERY_KEY=replace-with-strong-recovery-key
CORS_ORIGIN=https://tarispace.me,https://www.tarispace.me
PROD_API_BASE=https://www.tarispace.me/api
PROD_ADMIN_EMAIL=
PROD_ADMIN_PASSWORD=
